{
  "sway/workspaces": {
    "disable-scroll": true,
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": []
    }
  },
  "hyprand/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "Home",
      "2": "Work",
      "3": "Music",
      "4": "Game",
      "5": "Slush",
      "urgent": "´ü¬",
      "focused": "",
      "default": ""
    }
  },
  "hyprland/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/window": {
    "format": "{}",
    "max-length": 50,
    "tooltip": false
  },
  // "bluetooth": {
  //   "interval": 30,
  //   "format": "{icon}",
  //   // "format-alt": "{status}",
  //   "format-icons": {
  //     "enabled": "´Őô",
  //     "disabled": "´Üöss"
  //   },
  //   "on-click": "blueman"
  // },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "´ü«",
      "deactivated": "´ü░"
    },
    "tooltip": "true"
  },
  "tray": {
    //"icon-size": 14,
    "spacing": 4
  },
  "battery": {
    "bat": "BAT0",
    "format": "{capacity}% {icon}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },
  "battery#bat1": {
    "bat": "BAT1"
  },
  "clock#time": {
    "interval": 10,
    "format": "{:%H:%M}",
    "tooltip": false
  },
  "clock#date": {
    "interval": 20,
    //"format": "{:´ü│ %a %e/%m}",
    "format": "{:%a %e/%m}",
    // "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    //"today-format": "<b>{}</b>",
    "on-click": "gsimplecal",
    "tooltip": false
  },
  "temperature": {
    //"thermal-zone": 1,
    "interval": "1",
    "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
    "critical-threshold": 75,
    "format-critical": "´ü▒  {temperatureC}┬░C",
    "format": "{icon}  {temperatureC}┬░C",
    "format-icons": ["´Łź", "´őë", "´Łę"],
    "max-length": 8,
    "min-length": 7,
    "tooltip": false
  },
  "cpu": {
    "interval": 5,
    "format": "´őŤ {usage:2}%",
    // "format": "´őŤ  {max_frequency:1}GHz  ˘ĆĆ┤  {usage:2}%",
    "on-click": "kitty -e htop --sort-key PERCENT_CPU",
    "tooltip": false
  },
  "network": {
    // "interface": "wlan0", // (Optional) To force the use of this interface,
    "format-wifi": "<span color=\"#ebdbb2\">´çź</span>  {essid}",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} ´×ľ",
    "format-linked": "{ifname} (No IP) ´×ľ",
    "format-disconnected": "´Üö",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "family": "ipv4",
    "tooltip-format-wifi": "´çź  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\n´ŹŚ {bandwidthUpBits} ´Źö {bandwidthDownBits}",
    "tooltip-format-ethernet": "´×ľ {ifname}\nIP: {ipaddr}\n´ŹŚ {bandwidthUpBits} ´Źö {bandwidthDownBits}"
  },
  "custom/weather": {
    "exec": "curl 'https://wttr.in/heidelberg?format=1'",
    "interval": 3600,
    "on-click": "gnome-weather"
  },
  "pulseaudio": {
    "scroll-step": 3, // %, can be a float
    "format": "{icon} {volume:2}% {format_source}",
    "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
    "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
    "format-muted": "´Üę {format_source}",
    "format-source": "´ä░",
    "format-source-muted": "<span color=\"#fb4833\">´ä▒</span>",
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´ľÉ",
      "headset": "´ľÉ",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle"
  },
  "custom/cpugovernor": {
    "format": "{icon}",
    "interval": "once",
    "return-type": "json",
    "exec": "$HOME/.config/waybar/custom_modules/cpugovernor.sh",
    "min-length": 2,
    "max-length": 3,
    "signal": 8,
    "format-icons": {
      "perf": "´čĄ",
      "ondemand": "´ĺ┐"
    },
    "on-click": "$HOME/.config/waybar/custom_modules/cpugovernor.sh switch"
    // Requires cpupower to switch governors
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% {icon}",
    "format-icons": ["´ćů", "´äĹ"],
    "on-click": "light -S 100",
    "on-click-right": "light -S 10",
    "tooltip": false
  }
}
