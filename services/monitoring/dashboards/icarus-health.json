{
  "annotations": {
    "list": []
  },
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Failed systemd units",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(node_systemd_unit_state{state=\"failed\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Failed probes",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(probe_success == 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Available memory",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 * node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "green",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Maximum temperature",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "max(node_hwmon_temp_celsius)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "CPU usage",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Filesystem free space",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "100 * node_filesystem_avail_bytes{fstype!~\"tmpfs|ramfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|ramfs|overlay\"}",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Service probes",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "probe_success",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true
            },
            "renameByName": {
              "Value": "Healthy"
            }
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "Backup state",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "expr": "infra_backup_last_run_success",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "time() - infra_backup_last_run_timestamp_seconds",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Nix store size",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "expr": "infra_nix_store_size_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "System generations",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 22
      },
      "targets": [
        {
          "expr": "infra_nixos_system_generation_count",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Oldest generation age",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 22
      },
      "targets": [
        {
          "expr": "time() - infra_nixos_oldest_generation_timestamp_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Podman image size",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 22
      },
      "targets": [
        {
          "expr": "infra_podman_image_size_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Reclaimable Podman images",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "expr": "infra_podman_reclaimable_image_count",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Reclaimable Podman size",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 27
      },
      "targets": [
        {
          "expr": "infra_podman_reclaimable_image_size_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Housekeeping result",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 27
      },
      "targets": [
        {
          "expr": "infra_housekeeping_last_run_success and on(task) infra_housekeeping_last_run_timestamp_seconds > 0",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Failed"
                },
                "1": {
                  "text": "Successful"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Housekeeping age",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 27
      },
      "targets": [
        {
          "expr": "time() - (infra_housekeeping_last_run_timestamp_seconds > 0)",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Nix store growth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "infra_nix_store_size_bytes",
          "legendFormat": "Nix store",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Podman image growth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "expr": "infra_podman_image_size_bytes",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "infra_podman_reclaimable_image_size_bytes",
          "legendFormat": "Reclaimable",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Last reclaimed space",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "expr": "infra_housekeeping_last_reclaimed_bytes and on(task) infra_housekeeping_last_run_timestamp_seconds > 0",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Last housekeeping duration",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "targets": [
        {
          "expr": "infra_housekeeping_last_run_duration_seconds and on(task) infra_housekeeping_last_run_timestamp_seconds > 0",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["infrastructure", "icarus"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Icarus Health",
  "uid": "icarus-health",
  "version": 2
}
